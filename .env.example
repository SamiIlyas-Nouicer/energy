# ============================================================
# French Energy Intelligence Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── RTE France Open API ──────────────────────────────────────
# Register for free at: https://data.rte-france.com
RTE_CLIENT_ID=your-rte-client-id-here
RTE_CLIENT_SECRET=your-rte-client-secret-here

# ── Kafka ────────────────────────────────────────────────────
# Internal Docker: kafka:29092  |  Local dev: localhost:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── MinIO (S3-compatible storage) ────────────────────────────
# Internal Docker: http://minio:9000  |  Local dev: http://localhost:9000
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── MLflow ───────────────────────────────────────────────────
# Internal Docker: http://mlflow:5000  |  Local dev: http://localhost:5000
MLFLOW_TRACKING_URI=http://localhost:5000

# ── FastAPI ──────────────────────────────────────────────────
# Internal Docker: http://api:8000  |  Local dev: http://localhost:8000
API_URL=http://localhost:8000
